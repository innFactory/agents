{
  "name": "@librechat/agents",
  "version": "3.1.79",
  "main": "./dist/cjs/main.cjs",
  "module": "./dist/esm/main.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/main.mjs",
      "require": "./dist/cjs/main.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./langchain": {
      "import": "./dist/esm/langchain/index.mjs",
      "require": "./dist/cjs/langchain/index.cjs",
      "types": "./dist/types/langchain/index.d.ts"
    },
    "./langchain/language_models/chat_models": {
      "import": "./dist/esm/langchain/language_models/chat_models.mjs",
      "require": "./dist/cjs/langchain/language_models/chat_models.cjs",
      "types": "./dist/types/langchain/language_models/chat_models.d.ts"
    },
    "./langchain/messages": {
      "import": "./dist/esm/langchain/messages.mjs",
      "require": "./dist/cjs/langchain/messages.cjs",
      "types": "./dist/types/langchain/messages.d.ts"
    },
    "./langchain/messages/tool": {
      "import": "./dist/esm/langchain/messages/tool.mjs",
      "require": "./dist/cjs/langchain/messages/tool.cjs",
      "types": "./dist/types/langchain/messages/tool.d.ts"
    },
    "./langchain/google-common": {
      "import": "./dist/esm/langchain/google-common.mjs",
      "require": "./dist/cjs/langchain/google-common.cjs",
      "types": "./dist/types/langchain/google-common.d.ts"
    },
    "./langchain/openai": {
      "import": "./dist/esm/langchain/openai.mjs",
      "require": "./dist/cjs/langchain/openai.cjs",
      "types": "./dist/types/langchain/openai.d.ts"
    },
    "./langchain/prompts": {
      "import": "./dist/esm/langchain/prompts.mjs",
      "require": "./dist/cjs/langchain/prompts.cjs",
      "types": "./dist/types/langchain/prompts.d.ts"
    },
    "./langchain/runnables": {
      "import": "./dist/esm/langchain/runnables.mjs",
      "require": "./dist/cjs/langchain/runnables.cjs",
      "types": "./dist/types/langchain/runnables.d.ts"
    },
    "./langchain/tools": {
      "import": "./dist/esm/langchain/tools.mjs",
      "require": "./dist/cjs/langchain/tools.cjs",
      "types": "./dist/types/langchain/tools.d.ts"
    },
    "./langchain/utils/env": {
      "import": "./dist/esm/langchain/utils/env.mjs",
      "require": "./dist/cjs/langchain/utils/env.cjs",
      "types": "./dist/types/langchain/utils/env.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "langchain": [
        "dist/types/langchain/index.d.ts"
      ],
      "langchain/*": [
        "dist/types/langchain/*"
      ]
    }
  },
  "type": "module",
  "description": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/danny-avila/agents"
  },
  "author": "Danny Avila",
  "license": "MIT",
  "licenses": [
    {
      "type": "MIT",
      "url": "https://github.com/danny-avila/agents/blob/main/LICENSE"
    }
  ],
  "packageManager": "npm@10.5.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prepare": "node husky-setup.js",
    "prepublishOnly": "npm run build",
    "build": "NODE_ENV=production rollup -c && tsc -p tsconfig.build.json",
    "build:dev": "rollup -c",
    "start": "node dist/esm/main.js",
    "clean": "node ./config/clean.js",
    "script": "node -r dotenv/config --loader ./tsconfig-paths-bootstrap.mjs --experimental-specifier-resolution=node ./src/scripts/cli.ts",
    "bun:cli": "bun -r dotenv/config ./src/scripts/cli.ts --provider 'bedrock' --name 'Jo' --location 'New York, NY'",
    "start:cli": "node -r dotenv/config --loader ./tsconfig-paths-bootstrap.mjs --experimental-specifier-resolution=node ./src/scripts/cli.ts --provider 'openAI' --name 'Jo' --location 'New York, NY'",
    "content": "node -r dotenv/config --loader ./tsconfig-paths-bootstrap.mjs --experimental-specifier-resolution=node ./src/scripts/content.ts --provider 'anthropic' --name 'Jo' --location 'New York, NY'",
    "stream": "node -r dotenv/config --loader ./tsconfig-paths-bootstrap.mjs --experimental-specifier-resolution=node ./src/scripts/stream.ts --provider 'anthropic' --name 'Jo' --location 'New York, NY'",
    "code_exec": "node -r dotenv/config --loader ./tsconfig-paths-bootstrap.mjs --experimental-specifier-resolution=node ./src/scripts/code_exec.ts --provider 'openAI' --name 'Jo' --location 'New York, NY'",
    "image": "node -r dotenv/config --loader ./tsconfig-paths-bootstrap.mjs --experimental-specifier-resolution=node ./src/scripts/image.ts --provider 'google' --name 'Jo' --location 'New York, NY'",
    "code_exec_files": "node -r dotenv/config --loader ./tsconfig-paths-bootstrap.mjs --experimental-specifier-resolution=node ./src/scripts/code_exec_files.ts --provider 'openAI' --name 'Jo' --location 'New York, NY'",
    "code_exec_session": "node -r dotenv/config --loader ./tsconfig-paths-bootstrap.mjs --experimental-specifier-resolution=node ./src/scripts/code_exec_session.ts --provider 'openAI' --name 'Jo' --location 'New York, NY'",
    "code_exec_multi_session": "node -r dotenv/config --loader ./tsconfig-paths-bootstrap.mjs --experimental-specifier-resolution=node ./src/scripts/code_exec_multi_session.ts --provider 'openAI' --name 'Jo' --location 'New York, NY'",
    "code_exec_simple": "node -r dotenv/config --loader ./tsconfig-paths-bootstrap.mjs --experimental-specifier-resolution=node ./src/scripts/code_exec_simple.ts --provider 'openAI' --name 'Jo' --location 'New York, NY'",
    "simple": "node -r dotenv/config --loader ./tsconfig-paths-bootstrap.mjs --experimental-specifier-resolution=node ./src/scripts/simple.ts --provider 'bedrock' --name 'Jo' --location 'New York, NY'",
